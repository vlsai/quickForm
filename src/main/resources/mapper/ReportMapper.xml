<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.quickform.api.mapper.ReportMapper">

  <select id="getReportById" resultType="map">
    SELECT * FROM report WHERE id = #{reportId}
  </select>

  <select id="getReportByPageAndName" resultType="map">
    SELECT * FROM report WHERE page_code = #{pageCode} AND name = #{reportName} ORDER BY id DESC LIMIT 1
  </select>

  <select id="getLatestReportByPage" resultType="map">
    SELECT * FROM report WHERE page_code = #{pageCode} ORDER BY id DESC LIMIT 1
  </select>

  <select id="run" resultType="map">
    ${sql}
  </select>

</mapper>
